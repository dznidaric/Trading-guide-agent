# -----------------------------------------------
# Alpha-Guide - Required Environment Variables
# -----------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...

# --- Qdrant vector database (required) ---
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=...
# Set to "false" only if behind a corporate proxy that terminates TLS:
# QDRANT_VERIFY_TLS=false

# --- Tavily web search (required for web_search tool) ---
TAVILY_API_KEY=tvly-...

# --- Redis (optional - conversation memory; MemorySaver used if absent) ---
# REDIS_URL=redis://localhost:6379

# --- LangSmith tracing (optional) ---
# LANGCHAIN_API_KEY=lsv2_...

# --- Vercel / deployment ---
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com

# --- Frontend (set in Vercel dashboard or .env.local) ---
# NEXT_PUBLIC_API_URL=https://your-backend-url.com
