# ============================================================================
# Alpha-Guide — Environment Variables
#
# Rename this file to .env (local dev) or set these in Vercel → Settings →
# Environment Variables for production.
#
# NEVER commit the real .env file — it is already in .gitignore.
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# OpenAI API key — used for gpt-5-mini and text-embedding-3-small
OPENAI_API_KEY=sk-...

# Qdrant Cloud — vector database for document embeddings
QDRANT_URL=https://xxx.cloud.qdrant.io
QDRANT_API_KEY=

# ── Optional (but recommended for full functionality) ────────────────────────

# Tavily — web search tool for the agent
TAVILY_API_KEY=tvly-...

# LangSmith — tracing and observability (EU endpoint)
LANGCHAIN_API_KEY=lsv2_...

# Redis — persistent conversation memory (omit for in-memory fallback)
REDIS_URL=redis://...

# Trading212 — trade execution (default mock = simulated orders, no real API)
# TRADING212_MODE=mock
# TRADING212_MODE=live   # requires implementing Trading212RestClient.place_order
# TRADING212_API_BASE_URL=
# TRADING212_API_KEY=

# ── Deployment ───────────────────────────────────────────────────────────────

# Set to "production" on Vercel (auto-set via vercel.json env block).
# Controls: docs visibility, HSTS header, LangSmith project label.
ENVIRONMENT=local

# CORS — comma-separated allowed origins (Vercel auto-adds its own URLs)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Local dev only ───────────────────────────────────────────────────────────

# Override in .env.local so the Next.js frontend talks to the local uvicorn
# NEXT_PUBLIC_API_URL=http://localhost:8000

# If behind a corporate proxy that requires TLS bypass for Qdrant
# QDRANT_VERIFY_TLS=false
